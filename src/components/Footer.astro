---
import { useTrans } from '../i18n';

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTrans(locale);
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <ul class="nav-links">
      <li><a href="#about">{t('nav.about') as string}</a></li>
      <li><a href="#experience">{t('nav.experience') as string}</a></li>
      <li><a href="#projects">{t('nav.projects') as string}</a></li>
      <li><a href="#contact">{t('nav.contact') as string}</a></li>
    </ul>
    <p>&copy; {year} Zeeshan. {t('footer.copyright')}</p>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1.25rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-links a {
      font-size: 0.85rem;
    }
  }
</style>
