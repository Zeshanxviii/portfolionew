---
import Layout from '../../layouts/Layout.astro';
import { useTrans } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'es' } }, { params: { locale: 'ja' } }, { params: { locale: 'zh' } }];
}

const locale = Astro.params.locale || 'en';
const t = useTrans(locale);

const projects = t('projects.items') as { title: string; description: string; tech: string[]; liveUrl?: string; repoUrl?: string; }[];
const projectLabels = { liveDemo: t('projects.liveDemo') as string, sourceCode: t('projects.sourceCode') as string };
const frontendSkills = t('experience.frontend.skills') as { name: string; level: string }[];
const backendSkills = t('experience.backend.skills') as { name: string; level: string }[];
---

<Layout title="Portfolio" description="Full-stack developer portfolio" locale={locale}>
  <!-- HERO -->
  <section class="section hero" id="hero">
    <div class="container hero-grid">
      <div class="hero-photo-wrap">
        <img src="/hero-photo.jpg" alt={t('hero.name') as string} class="hero-photo" />
      </div>
      <div class="hero-text">
        <p class="greeting">{t('hero.greeting') as string}</p>
        <h1>{t('hero.name') as string}</h1>
        <p class="title">{t('hero.title') as string}</p>
        <div class="hero-buttons">
          <a href="/resume.pdf" class="btn btn-primary" download>{t('hero.downloadCv') as string}</a>
          <a href="#contact" class="btn btn-secondary">{t('hero.contactInfo') as string}</a>
        </div>
        <div class="hero-socials">
          <a href="https://linkedin.com/in/your-handle" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://github.com/your-handle" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-content">
        <div class="about-image">
          <img src="/about-photo.jpg" alt={t('hero.name') as string} class="about-photo" />
        </div>
        <div class="about-info">
          <div class="about-cards">
            <div class="about-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <h3>{t('about.experience.title') as string}</h3>
              <p>{t('about.experience.desc') as string}</p>
            </div>
            <div class="about-card">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
              <h3>{t('about.education.title') as string}</h3>
              <p>{t('about.education.desc') as string}</p>
            </div>
          </div>
          <p class="about-bio">{t('about.bio') as string}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="section section-alt" id="experience">
    <div class="container">
      <div class="section-top">
        <p class="section-label">{t('experience.eyebrow') as string}</p>
        <h2 class="section-title">{t('experience.title') as string}</h2>
      </div>
      <div class="skills-grid">
        <div class="skill-category">
          <h3>{t('experience.frontend.title') as string}</h3>
          <div class="skill-items">
            {frontendSkills.map((skill) => (
              <div class="skill-item">
                <svg class="badge" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="var(--accent)" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" fill="var(--accent)"/><path d="m9 12 2 2 4-4" stroke="#fff"/></svg>
                <span class="skill-text">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-level">{skill.level}</span>
                </span>
              </div>
            ))}
          </div>
        </div>
        <div class="skill-category">
          <h3>{t('experience.backend.title') as string}</h3>
          <div class="skill-items">
            {backendSkills.map((skill) => (
              <div class="skill-item">
                <svg class="badge" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="var(--accent)" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z" fill="var(--accent)"/><path d="m9 12 2 2 4-4" stroke="#fff"/></svg>
                <span class="skill-text">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-level">{skill.level}</span>
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-top">
        <p class="section-label">{t('projects.eyebrow') as string}</p>
        <h2 class="section-title">{t('projects.title') as string}</h2>
      </div>
      <div class="projects-grid">
        {projects.map((p) => (
          <div class="project-card">
            <div class="project-img">
              <span class="project-placeholder">{p.title.charAt(0)}</span>
            </div>
            <div class="project-body">
              <h3>{p.title}</h3>
              <p>{p.description}</p>
              <div class="project-tech">
                {p.tech.map((tech) => <span class="tech-tag">{tech}</span>)}
              </div>
              <div class="project-links">
                {p.liveUrl && <a href={p.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm">{projectLabels.liveDemo}</a>}
                {p.repoUrl && <a href={p.repoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline">{projectLabels.sourceCode}</a>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section section-alt" id="contact">
    <div class="container">
      <div class="section-top">
        <p class="section-label">{t('contact.eyebrow') as string}</p>
        <h2 class="section-title">{t('contact.title') as string}</h2>
      </div>
      <div class="contact-card">
        <a href={`mailto:${t('contact.email') as string}`} class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>{t('contact.email') as string}</span>
        </a>
        <span class="contact-divider" aria-hidden="true"></span>
        <a href="https://linkedin.com/in/your-handle" target="_blank" rel="noopener noreferrer" class="contact-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          <span>{t('contact.linkedin') as string}</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <nav class="footer-nav">
      <a href="#about">{t('nav.about') as string}</a>
      <a href="#experience">{t('nav.experience') as string}</a>
      <a href="#projects">{t('nav.projects') as string}</a>
      <a href="#contact">{t('nav.contact') as string}</a>
    </nav>
    <p class="footer-copy">{t('footer.copyright') as string}</p>
  </footer>
</Layout>

<style>
  .section {
    padding: 6rem 1.5rem;
    scroll-margin-top: 90px;
  }

  .section-alt {
    background: var(--bg-secondary);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-top {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text);
    margin: 0;
  }

  /* Hero */
  .hero {
    padding-top: 9rem;
    padding-bottom: 5rem;
  }

  .hero-grid {
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .hero-photo-wrap {
    flex: 0 0 380px;
    width: 380px;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 4 / 4.5;
    object-fit: cover;
    display: block;
  }

  .hero-text {
    text-align: left;
  }

  .greeting {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin: 0 0 0.25rem;
  }

  h1 {
    font-size: 3.25rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .title {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin: 0 0 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn {
    padding: 0.75rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 999px;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: var(--shadow-sm);
  }

  .btn-primary:hover {
    background: var(--accent-light);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .btn-secondary {
    background: var(--card-bg);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--bg-secondary);
    border-color: var(--text-secondary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .btn-sm {
    padding: 0.5rem 1.1rem;
    font-size: 0.85rem;
    border-radius: 10px;
  }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    box-shadow: none;
  }

  .btn-outline:hover {
    background: var(--bg-secondary);
    border-color: var(--text-secondary);
  }

  .hero-socials {
    display: flex;
    gap: 1rem;
  }

  .hero-socials a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .hero-socials a:hover {
    background: var(--accent-light);
    transform: translateY(-2px);
  }

  /* About */
  .about-content {
    display: flex;
    gap: 4rem;
    align-items: center;
    max-width: 950px;
    margin: 0 auto;
  }

  .about-image {
    flex-shrink: 0;
    width: 320px;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 4 / 4.5;
    object-fit: cover;
    display: block;
  }

  .about-info {
    flex: 1;
  }

  .about-cards {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .about-card {
    flex: 1;
    min-width: 0;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .about-card svg {
    margin: 0 auto 0.75rem;
    color: var(--accent);
  }

  .about-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: var(--text);
  }

  .about-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
    white-space: pre-line;
    line-height: 1.5;
  }

  .about-bio {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Skills */
  .skills-grid {
    display: flex;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .skill-category {
    flex: 1;
    min-width: 0;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .skill-category h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 1rem;
  }

  .skill-item {
    flex: 0 0 calc(50% - 0.5rem);
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .badge {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .skill-text {
    display: flex;
    flex-direction: column;
  }

  .skill-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .skill-level {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  /* Projects */
  .projects-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .project-card {
    flex: 1 1 320px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: var(--shadow-sm);
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  .project-img {
    height: 160px;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border);
  }

  .project-placeholder {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent-light);
    opacity: 0.5;
  }

  .project-body {
    padding: 1.5rem;
  }

  .project-body h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .project-body p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tech-tag {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--bg-secondary);
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--border);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  /* Contact */
  .contact-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    max-width: fit-content;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--card-bg);
    box-shadow: var(--shadow-sm);
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    transition: color 0.2s ease;
  }

  .contact-link svg {
    flex-shrink: 0;
  }

  .contact-link:hover {
    color: var(--accent-light);
  }

  .contact-divider {
    width: 1px;
    height: 22px;
    background: var(--border);
  }

  /* Footer */
  .site-footer {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
  }

  .footer-nav {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .footer-nav a {
    color: var(--text);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .footer-nav a:hover {
    color: var(--text-secondary);
  }

  .footer-copy {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .section {
      padding: 4rem 1.25rem;
    }

    .hero-grid {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }

    .hero-photo-wrap {
      flex: 0 0 auto;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }

    .hero-text {
      text-align: center;
    }

    .hero-buttons,
    .hero-socials {
      justify-content: center;
    }

    h1 {
      font-size: 2.5rem;
    }

    .about-content {
      flex-direction: column;
      gap: 2rem;
    }

    .about-image {
      width: 240px;
      margin: 0 auto;
    }

    .about-cards {
      flex-direction: column;
    }

    .skills-grid {
      flex-direction: column;
      gap: 1.25rem;
    }

    .skill-items {
      flex-direction: column;
    }

    .skill-item {
      flex: 0 0 auto;
    }

    .projects-grid {
      flex-direction: column;
    }

    .section-title {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 7rem;
      padding-bottom: 4rem;
    }

    h1 {
      font-size: 2rem;
    }

    .title {
      font-size: 1rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .project-img {
      height: 130px;
    }

    .project-links {
      flex-direction: column;
    }

    .contact-card {
      flex-direction: column;
      border-radius: var(--radius);
      width: 100%;
    }

    .contact-divider {
      width: 100%;
      height: 1px;
    }
  }
</style>