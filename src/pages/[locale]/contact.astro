---
import Layout from '../../layouts/Layout.astro';
import { useTrans } from '../../i18n';
import GithubIcon from '../../components/icons/GithubIcon.astro';
import LinkedinIcon from '../../components/icons/LinkedinIcon.astro';
import MailIcon from '../../components/icons/MailIcon.astro';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'es' } }, { params: { locale: 'hi' } }, { params: { locale: 'ur' } }, { params: { locale: 'ar' } }, { params: { locale: 'ja' } }, { params: { locale: 'zh' } }];
}

const locale = Astro.params.locale || 'en';
const t = useTrans(locale);
---

<Layout title="Contact — Zeeshan" description="Get in touch" locale={locale}>
  <section class="page-header">
    <div class="container">
      <h1>{t('contact.title') as string}</h1>
      <p>{t('contact.subtitle') as string}</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <form class="contact-form" netlify>
          <div class="form-group">
            <label for="name">{t('contact.form.name') as string}</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">{t('contact.form.email') as string}</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="subject">{t('contact.form.subject') as string}</label>
            <input type="text" id="subject" name="subject" />
          </div>
          <div class="form-group">
            <label for="message">{t('contact.form.message') as string}</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn">{t('contact.form.send') as string}</button>
        </form>

        <div class="contact-info">
          <div class="info-item">
            <h3>{t('contact.email') as string}</h3>
            <a href="mailto:zeeshan@example.com">
              <MailIcon size={16} /> zeeshan@example.com
            </a>
          </div>
          <div class="info-item">
            <h3>{t('contact.github') as string}</h3>
            <a href="https://github.com/zeeshan" target="_blank" rel="noopener noreferrer">
              <GithubIcon size={16} /> github.com/zeeshan
            </a>
          </div>
          <div class="info-item">
            <h3>{t('contact.linkedin') as string}</h3>
            <a href="https://linkedin.com/in/zeeshan" target="_blank" rel="noopener noreferrer">
              <LinkedinIcon size={16} /> linkedin.com/in/zeeshan
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0;
  }

  .contact-section {
    padding: 2rem 0 4rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 700px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  input,
  textarea {
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text);
    transition: border-color 0.2s;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }

  .btn {
    align-self: flex-start;
    padding: 0.75rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn:hover {
    background: var(--accent-light);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.25rem;
  }

  .info-item h3 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin: 0 0 0.3rem;
  }

  .info-item a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    word-break: break-all;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 3rem 1.25rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
    }

    .contact-section {
      padding: 1rem 0 3rem;
    }

    .contact-grid {
      gap: 1.5rem;
    }
  }
</style>
