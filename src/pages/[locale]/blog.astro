---
import Layout from '../../layouts/Layout.astro';
import { useTrans } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'es' } }, { params: { locale: 'hi' } }, { params: { locale: 'ur' } }, { params: { locale: 'ar' } }, { params: { locale: 'ja' } }, { params: { locale: 'zh' } }];
}

const locale = Astro.params.locale || 'en';
const t = useTrans(locale);
const posts = t('blog.posts') as { title: string; date: string; excerpt: string; tags: string[] }[];
---

<Layout title="Blog — Zeeshan" description="Thoughts on development and design" locale={locale}>
  <section class="page-header">
    <div class="container">
      <h1>{t('blog.title') as string}</h1>
      <p>{t('blog.subtitle') as string}</p>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      <div class="posts-list">
        {posts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <time datetime={post.date}>{post.date}</time>
            </div>
            <h2><a href="#">{post.title}</a></h2>
            <p>{post.excerpt}</p>
            <div class="tags">
              {post.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .page-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0;
  }

  .posts-section {
    padding: 2rem 0 4rem;
  }

  .posts-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .post-meta {
    margin-bottom: 0.5rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  h2 {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    font-weight: 700;
  }

  h2 a {
    color: var(--text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--accent);
  }

  p {
    margin: 0 0 1rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-secondary);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 3rem 1.25rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
    }

    .page-header p {
      font-size: 1rem;
    }

    .post-card {
      padding: 1.25rem;
    }

    h2 {
      font-size: 1.15rem;
    }
  }
</style>
